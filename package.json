{
  "name": "nexaros",
  "version": "0.1.0",
  "private": true,
  "description": "NexaROS — AI-Powered Restaurant Operating System",
  "scripts": {
    "dev": "pnpm --filter @nexaros/backend run start:dev",
    "dev:marketing": "pnpm --filter @nexaros/marketing-web run dev",
    "dev:customer": "pnpm --filter @nexaros/customer-web run dev",
    "dev:all": "pnpm run --parallel dev dev:marketing dev:customer",
    "build": "pnpm --filter @nexaros/backend run build",
    "lint": "pnpm -r run lint",
    "test": "pnpm -r run test",
    "db:migrate": "pnpm --filter @nexaros/backend run db:migrate",
    "db:seed": "pnpm --filter @nexaros/backend run db:seed",
    "db:studio": "pnpm --filter @nexaros/backend run db:studio",
    "docker:up": "docker compose -f docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f docker/docker-compose.yml down",
    "docker:logs": "docker compose -f docker/docker-compose.yml logs -f"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["*"]
  }
}
