model DailyAnalyticsSnapshot {
  id              String   @id @default(cuid())
  tenantId        String
  branchId        String?
  date            DateTime
  // Revenue
  grossRevenue    Decimal  @default(0) @db.Decimal(12, 2)
  netRevenue      Decimal  @default(0) @db.Decimal(12, 2)
  taxCollected    Decimal  @default(0) @db.Decimal(12, 2)
  discounts       Decimal  @default(0) @db.Decimal(12, 2)
  refunds         Decimal  @default(0) @db.Decimal(12, 2)
  averageOrderValue Decimal @default(0) @db.Decimal(12, 2)
  revenueByPaymentMethod Json?
  // Orders
  totalOrders     Int      @default(0)
  completedOrders Int      @default(0)
  cancelledOrders Int      @default(0)
  dineInOrders    Int      @default(0)
  takeawayOrders  Int      @default(0)
  deliveryOrders  Int      @default(0)
  avgCompletionMinutes Decimal? @db.Decimal(8, 2)
  // Customers
  newCustomers    Int      @default(0)
  returningCustomers Int    @default(0)
  retentionRate   Decimal? @db.Decimal(5, 2)
  // Menu
  topItems        Json?
  revenueByCategory Json?
  // Inventory
  foodCost        Decimal? @db.Decimal(12, 2)
  wasteValue      Decimal? @db.Decimal(12, 2)
  // Staff
  laborCost       Decimal? @db.Decimal(12, 2)
  salesPerStaff   Decimal? @db.Decimal(12, 2)
  // Meta
  computedAt      DateTime @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, branchId, date])
  @@index([tenantId, date])
  @@index([branchId, date])
  @@map("daily_analytics_snapshots")
}

model HourlyAnalyticsSnapshot {
  id           String   @id @default(cuid())
  tenantId     String
  branchId     String?
  date         DateTime
  hour         Int
  revenue      Decimal  @default(0) @db.Decimal(12, 2)
  orders       Int      @default(0)
  avgOrderValue Decimal? @db.Decimal(12, 2)
  computedAt   DateTime @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, branchId, date, hour])
  @@index([tenantId, date])
  @@index([branchId, date])
  @@map("hourly_analytics_snapshots")
}

model BranchAnalyticsSnapshot {
  id              String   @id @default(cuid())
  tenantId        String
  branchId        String
  date            DateTime
  grossRevenue    Decimal  @default(0) @db.Decimal(12, 2)
  netRevenue      Decimal  @default(0) @db.Decimal(12, 2)
