model SharedItemAllocation {
  id             String      @id @default(cuid())
  sharedItemId   String
  sharedItem     SharedItem  @relation(fields: [sharedItemId], references: [id], onDelete: Cascade)
  guestSessionId String
  guestSession   GuestSession @relation(fields: [guestSessionId], references: [id], onDelete: Cascade)
  percentage     Decimal?    @db.Decimal(5, 2)
  amount         Decimal?    @db.Decimal(10, 2)
  createdAt      DateTime    @default(now())

  @@unique([sharedItemId, guestSessionId])
  @@index([sharedItemId])
  @@index([guestSessionId])
  @@map("shared_item_allocations")
}

model SplitAllocation {
  id               String                @id @default(cuid())
  diningSessionId  String
  diningSession    DiningSession         @relation(fields: [diningSessionId], references: [id], onDelete: Cascade)
  guestSessionId   String
  guestSession     GuestSession          @relation(fields: [guestSessionId], references: [id], onDelete: Cascade)
  splitType        SplitType
  itemTotal        Decimal               @db.Decimal(10, 2)
  sharedTotal      Decimal               @default(0) @db.Decimal(10, 2)
  taxAmount        Decimal               @default(0) @db.Decimal(10, 2)
  discountAmount   Decimal               @default(0) @db.Decimal(10, 2)
  tipAmount        Decimal               @default(0) @db.Decimal(10, 2)
  totalOwed        Decimal               @db.Decimal(10, 2)
  totalPaid        Decimal               @default(0) @db.Decimal(10, 2)
  status           SplitAllocationStatus @default(PENDING)
  paidAt           DateTime?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@unique([diningSessionId, guestSessionId])
  @@index([diningSessionId])
  @@index([guestSessionId])
  @@index([diningSessionId, status])
  @@map("split_allocations")
}

model PaymentTransaction {
  id              String       @id @default(cuid())
  paymentId       String
  payment         Payment      @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  guestSessionId  String?
  guestSession    GuestSession? @relation(fields: [guestSessionId], references: [id], onDelete: SetNull)
  method          PaymentMethod
  amount          Decimal      @db.Decimal(10, 2)
  reference       String?
  status          PaymentStatus @default(PENDING)
  processedAt     DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([paymentId])
  @@index([guestSessionId])
  @@map("payment_transactions")
}

model SessionTimeline {
  id              String    @id @default(cuid())
  diningSessionId String
  diningSession   DiningSession @relation(fields: [diningSessionId], references: [id], onDelete: Cascade)
  event           String
  description     String?
  metadata        Json?
  createdAt       DateTime  @default(now())

  @@index([diningSessionId])
  @@index([diningSessionId, createdAt])
  @@map("session_timelines")
}

// ═══════════════════════════════════════════════════════════════
// WHATSAPP BUSINESS PLATFORM
// ═══════════════════════════════════════════════════════════════

enum WhatsAppAccountStatus {
  ACTIVE
  SUSPENDED
  PENDING_VERIFICATION
  CONFIGURATION_IN_PROGRESS
  DISABLED

  @@map("whatsapp_account_statuses")
}

enum WhatsAppMessageDirection {
  INBOUND
  OUTBOUND

  @@map("whatsapp_message_directions")
}

enum WhatsAppMessageStatus {
  SENT
  DELIVERED
  READ
  FAILED
  PENDING
  UNDELIVERABLE

  @@map("whatsapp_message_statuses")
}

enum WhatsAppMessageType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  INTERACTIVE
  TEMPLATE
  LOCATION
  CONTACT
  REACTION

  @@map("whatsapp_message_types")
}

enum WhatsAppTemplateCategory {
  MARKETING
  UTILITY
  AUTHENTICATION

  @@map("whatsapp_template_categories")
}

enum WhatsAppTemplateStatus {
  PENDING
  APPROVED
  REJECTED
  ARCHIVED
  PAUSED

  @@map("whatsapp_template_statuses")
}

enum WhatsAppAutomationTrigger {
  NEW_SESSION
  GREETING
  MENU_REQUEST
  ORDER_PLACED
  PAYMENT_RECEIVED
  ORDER_READY
  DELIVERY_UPDATE
  CUSTOM_KEYWORD
  INACTIVITY_TIMEOUT
  FIRST_ORDER

  @@map("whatsapp_automation_triggers")
}

enum WhatsAppAutomationAction {
  SEND_TEMPLATE
  SEND_TEXT
  SEND_CATALOG
  REQUEST_LOCATION
  REQUEST_CONTACT
  TRANSFER_TO_AGENT
  CREATE_ORDER
  APPLY_DISCOUNT
  SEND_MENU

  @@map("whatsapp_automation_actions")
}

enum WhatsAppCampaignStatus {
  DRAFT
  SCHEDULED
  RUNNING
  PAUSED
  COMPLETED
  FAILED

  @@map("whatsapp_campaign_statuses")
}

// ─────────────────────────────────────────────
// WhatsApp Business Account Configuration
// ─────────────────────────────────────────────

model WhatsAppAccount {
  id                  String                @id @default(cuid())
  tenantId            String
  tenant              Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  phoneNumberId       String                @unique
  wabaId              String                @unique
  businessName        String
  phoneNumber         String
  displayPhoneNumber  String?
  verifiedName        String?
  qualityRating       String?
  status              WhatsAppAccountStatus @default(PENDING_VERIFICATION)
  accessToken         String
  appSecret           String
  webhookVerifyToken  String
  apiVersion          String                @default("v18.0")
  messagingLimit      Int                   @default(1000)
  isDefault           Boolean               @default(false)
  metadata            Json?
  lastSyncAt          DateTime?
  expiresAt           DateTime?
  version             Int                   @default(1)
  deletedAt           DateTime?
  createdBy           String?
  updatedBy           String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  messages            WhatsAppMessage[]
  templates           WhatsAppTemplate[]
  campaigns           WhatsAppBulkCampaign[]
  automations         WhatsAppAutomation[]
  analytics           WhatsAppAnalytics[]

  @@index([tenantId])
  @@index([tenantId, isDefault])
  @@index([phoneNumberId])
  @@map("whatsapp_accounts")
}

// ─────────────────────────────────────────────
// WhatsApp Message Logs
// ─────────────────────────────────────────────

model WhatsAppMessage {
  id                  String                @id @default(cuid())
  accountId           String
  account             WhatsAppAccount       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  tenantId            String
  tenant              Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  platformMessageId   String                @unique
  conversationSessionId String?
  conversationSession ConversationSession?  @relation(fields: [conversationSessionId], references: [id], onDelete: SetNull)
  orderId             String?
  order               Order?                @relation(fields: [orderId], references: [id], onDelete: SetNull)
  direction           WhatsAppMessageDirection
  type                WhatsAppMessageType
  status              WhatsAppMessageStatus @default(PENDING)
  from                String
  to                  String
  textContent         String?
  mediaUrl            String?
  mediaType           String?
  templateName        String?
  templateParams      Json?
  interactivePayload  Json?
  rawPayload          Json?
  error               String?
  errorCode           String?
  sentAt              DateTime?
  deliveredAt         DateTime?
  readAt              DateTime?
  failedAt            DateTime?
  metadata            Json?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  @@index([tenantId])
  @@index([accountId])
  @@index([conversationSessionId])
  @@index([orderId])
  @@index([from, tenantId])
  @@index([to, tenantId])
  @@index([status])
  @@index([createdAt])
  @@index([platformMessageId])
  @@map("whatsapp_messages")
}

// ─────────────────────────────────────────────
// WhatsApp Message Templates (Meta Approval)
// ─────────────────────────────────────────────

model WhatsAppTemplate {
  id                  String                @id @default(cuid())
  accountId           String
  account             WhatsAppAccount       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  tenantId            String
  tenant              Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name                String
  category            WhatsAppTemplateCategory
  language            String                @default("en")
  status              WhatsAppTemplateStatus @default(PENDING)
  headerType          String?
  headerText          String?
  headerMediaUrl      String?
  bodyText            String
  footerText          String?
  buttons             Json?
  variables           String[]
  rejectionReason     String?
  submittedAt         DateTime?
  approvedAt          DateTime?
  rejectedAt          DateTime?
  metaTemplateId      String?
  version             Int                   @default(1)
  isActive            Boolean               @default(true)
  deletedAt           DateTime?
  createdBy           String?
  updatedBy           String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  usages              WhatsAppTemplateUsage[]
  automations         WhatsAppAutomation[]

  @@unique([accountId, name, language])
  @@index([tenantId])
  @@index([accountId])
  @@index([status])
  @@index([category])
  @@map("whatsapp_templates")
}

// ─────────────────────────────────────────────
// WhatsApp Template Usage Tracking
// ─────────────────────────────────────────────

model WhatsAppTemplateUsage {
  id                  String    @id @default(cuid())
  templateId          String
  template            WhatsAppTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  tenantId            String
  tenant              Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  campaignId          String?
  campaign            WhatsAppBulkCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  sentCount           Int       @default(0)
  deliveredCount      Int       @default(0)
  readCount           Int       @default(0)
  failedCount         Int       @default(0)
  usageDate           DateTime  @default(now())
  metadata            Json?
  createdAt           DateTime  @default(now())

  @@index([templateId])
  @@index([tenantId])
  @@index([campaignId])
  @@index([usageDate])
  @@map("whatsapp_template_usages")
}

// ─────────────────────────────────────────────
// WhatsApp Bulk Campaigns
// ─────────────────────────────────────────────

model WhatsAppBulkCampaign {
  id                  String                @id @default(cuid())
  accountId           String
  account             WhatsAppAccount       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  tenantId            String
  tenant              Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name                String
  description         String?
  status              WhatsAppCampaignStatus @default(DRAFT)
  templateName        String
  templateLanguage    String                @default("en")
  audienceSegmentId   String?
  scheduledAt         DateTime?
  startedAt           DateTime?
  completedAt         DateTime?
  totalRecipients     Int                   @default(0)
  sentCount           Int                   @default(0)
  deliveredCount      Int                   @default(0)
  readCount           Int                   @default(0)
  failedCount         Int                   @default(0)
  revenue             Decimal?              @db.Decimal(10, 2)
  metadata            Json?
  error               String?
  version             Int                   @default(1)
  deletedAt           DateTime?
  createdBy           String?
  updatedBy           String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  usages              WhatsAppTemplateUsage[]

  @@index([tenantId])
  @@index([accountId])
  @@index([status])
  @@index([scheduledAt])
  @@map("whatsapp_bulk_campaigns")
}

// ─────────────────────────────────────────────
// WhatsApp Automation Rules
// ─────────────────────────────────────────────

model WhatsAppAutomation {
  id                  String                @id @default(cuid())
  accountId           String
  account             WhatsAppAccount       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  tenantId            String
  tenant              Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name                String
  description         String?
  isActive            Boolean               @default(true)
  priority            Int                   @default(0)
  trigger             WhatsAppAutomationTrigger
  triggerConditions   Json?
  action              WhatsAppAutomationAction
  actionConfig        Json?
  templateId          String?
  template            WhatsAppTemplate?      @relation(fields: [templateId], references: [id], onDelete: SetNull)
  maxExecutions       Int?
  executionCount      Int                   @default(0)
  cooldownSeconds     Int                   @default(0)
  lastExecutedAt      DateTime?
  metadata            Json?
  version             Int                   @default(1)
  deletedAt           DateTime?
  createdBy           String?
  updatedBy           String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  @@index([tenantId])
  @@index([accountId])
  @@index([tenantId, trigger])
  @@index([isActive, priority])
  @@map("whatsapp_automations")
}

// ─────────────────────────────────────────────
// WhatsApp Analytics (Daily Aggregates)
// ─────────────────────────────────────────────

model WhatsAppAnalytics {
  id                  String    @id @default(cuid())
  accountId           String
  account             WhatsAppAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  tenantId            String
  tenant              Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  date                DateTime  @db.Date
  messagesSent        Int       @default(0)
  messagesDelivered   Int       @default(0)
  messagesRead        Int       @default(0)
  messagesFailed      Int       @default(0)
  conversationsStarted Int      @default(0)
  ordersPlaced        Int       @default(0)
  revenue             Decimal   @default(0) @db.Decimal(10, 2)
  templatesSent       Int       @default(0)
  campaignsSent       Int       @default(0)
  avgResponseTimeMs   Int?
  metadata            Json?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([accountId, date])
  @@index([tenantId])
  @@index([date])
  @@index([accountId, date])
  @@map("whatsapp_analytics")
}

model MediaAsset {
  id             String   @id @default(cuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  filename       String
  originalName   String
  mimeType       String
  size           Int
  url            String
  thumbnailUrl   String?
  folder         String   @default("/")
  tags           String[]
  width          Int?
  height         Int?
  metadata       Json?
  deletedAt      DateTime?
  createdBy      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, folder])
  @@index([tenantId, mimeType])
  @@map("media_assets")
}

// ─────────────────────────────────────────────
// WEBSITE CMS CONTENT: Testimonials, FAQs, Blog, Events
// ─────────────────────────────────────────────

model Testimonial {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customerName String
  rating       Int      @default(5)
  text         String
  avatar       String?
  isFeatured   Boolean  @default(false)
  isVerified   Boolean  @default(false)
  branchId     String?
  deletedAt    DateTime?
  createdBy    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId])
  @@map("testimonials")
}

model Faq {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  question     String
  answer       String
  category     String?
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  deletedAt    DateTime?
  createdBy    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId])
  @@map("faqs")
}

model BlogPost {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title       String
  slug        String
  content     String
  excerpt     String?
  coverImage  String?
  author      String?
  tags        String[]
  status      String    @default("DRAFT")
  publishedAt DateTime?
  deletedAt   DateTime?
  createdBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("blog_posts")
}

model Event {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime?
  image       String?
  location    String?
  isVirtual   Boolean   @default(false)
  status      String    @default("UPCOMING")
  deletedAt   DateTime?
  createdBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([tenantId])
  @@map("events")
}
