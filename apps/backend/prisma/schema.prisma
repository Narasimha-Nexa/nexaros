  @@unique([internalBranchId, channel])
  @@index([channel])
  @@index([externalRestaurantId])
  @@map("channel_restaurant_mappings")
}

model ChannelItemMapping {
  id                  String                   @id @default(cuid())
  restaurantMappingId String
  restaurantMapping   ChannelRestaurantMapping @relation(fields: [restaurantMappingId], references: [id], onDelete: Cascade)
