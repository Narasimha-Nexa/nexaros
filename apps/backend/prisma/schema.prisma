// ═══════════════════════════════════════════════════════════════
// PROVISIONING LIFECYCLE
// ═══════════════════════════════════════════════════════════════

model RestaurantProvisionRequest {
  id    String @id @default(cuid())
  token String @unique @default(cuid())

  status String @default("DRAFT") // DRAFT | PAYMENT_PENDING | PAYMENT_SUCCESS | PROVISIONING | COMPLETED | FAILED

  // Restaurant details
  restaurantName String
  slug           String?
  subdomain      String?
  phone          String?
  email          String?
  address        String?
  city           String?
  state          String?
  country        String? @default("India")
  cuisineType    String?
  gstNumber      String?
  timezone       String? @default("Asia/Kolkata")
  currency       String? @default("INR")
  logo           String?

  // Owner details
  ownerName       String
  ownerEmail      String
  ownerPhone      String?
  password        String?
  autoGenPassword Boolean @default(true)

  // Provisioning mode: new_business | add_branch
  mode             String?  @default("new_business")
  existingTenantId String?
  branchName       String?

  // Plan & billing
  planId       String?
  plan         PlatformPlan? @relation(fields: [planId], references: [id], onDelete: SetNull)
  billingCycle String?       @default("MONTHLY")
  customAmount Decimal? @db.Decimal(12, 2) // Admin-entered price for custom/enterprise plans

  // Coupon
  couponCode     String?
  discountAmount Decimal? @default(0) @db.Decimal(12, 2)
  discountType   String?

  // Tax calculation
  subtotal     Decimal? @default(0) @db.Decimal(12, 2)
  taxRate      Decimal? @default(18) @db.Decimal(5, 2)
  taxAmount    Decimal? @default(0) @db.Decimal(12, 2)
  totalAmount  Decimal? @default(0) @db.Decimal(12, 2)
  currencyCode String?  @default("INR")

  // Payment
  paymentProvider  String? @default("razorpay")
  paymentOrderId   String?
  paymentId        String?
  paymentSignature String?
  paymentStatus    String? @default("UNPAID") // UNPAID | PENDING | CAPTURED | FAILED | REFUNDED

  // Provisioning result
  tenantId       String?
  tenant         Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId       String?
  ownerId        String?
  staffId        String?
  subscriptionId String?

  // Provisioning progress (JSON: {step, message, completedSteps[], failedStep?})
  progress   Json?
  error      String?
  retryCount Int     @default(0)

  // Audit
  createdBy String?
  ipAddress String?
  userAgent String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?
  expiresAt   DateTime?

  @@index([token])
  @@index([status])
  @@index([tenantId])
  @@index([createdAt])
  @@map("restaurant_provision_requests")
}

model PaymentEvent {
  id                 String   @id @default(cuid())
  provisionRequestId String?
  tenantId           String?
  event              String // PAYMENT_INITIATED | PAYMENT_CAPTURED | PAYMENT_FAILED | PAYMENT_REFUNDED
  provider           String   @default("razorpay")
  providerOrderId    String?
  providerPaymentId  String?
  amount             Decimal? @db.Decimal(12, 2)
  currency           String?  @default("INR")
  status             String   @default("INITIATED") // INITIATED | CAPTURED | FAILED | REFUNDED
  metadata           Json?
  ipAddress          String?
  createdAt          DateTime @default(now())

  @@index([provisionRequestId])
  @@index([tenantId])
  @@index([event])
  @@map("payment_events")
}

