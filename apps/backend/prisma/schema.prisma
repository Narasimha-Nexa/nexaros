generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum TenantStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
  DELETED
}

enum BranchStatus {
  ACTIVE
  PAUSED
  CLOSED
  ARCHIVED
}

enum StaffStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  ON_LEAVE
  TERMINATED
}

enum BranchType {
  PRIMARY
  SECONDARY
  CLOUD_KITCHEN
  DARK_STORE
  POP_UP
}

enum DeviceStatus {
  ONLINE
  OFFLINE
  MAINTENANCE
  RETIRED
}

enum OrderSource {
  POS
  QR
  APP
  WEBSITE
  SWIGGY
  ZOMATO
  WHATSAPP
  INSTAGRAM
  PHONE
  WALK_IN
  OTHER
}

// ─────────────────────────────────────────────
// OWNER PROFILE (Cross-Tenant Identity)
// ─────────────────────────────────────────────

model OwnerProfile {
  id             String    @id @default(cuid())
  email          String    @unique
  phone          String?   @unique
  password       String
  name           String
  avatar         String?
  isActive       Boolean   @default(true)
  lastLoginAt    DateTime?
  mfaEnabled     Boolean   @default(false)
  mfaSecret      String?
  version        Int       @default(1)
  deletedAt      DateTime?
  createdBy      String?
  updatedBy      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenants Tenant[]

  @@map("owner_profiles")
}

// ─────────────────────────────────────────────
// TENANT LAYER
// ─────────────────────────────────────────────

model Tenant {
  id              String       @id @default(cuid())
  ownerProfileId  String
  ownerProfile    OwnerProfile @relation(fields: [ownerProfileId], references: [id])
  name            String
  slug            String       @unique
  subdomain       String?      @unique
  customDomain    String?      @unique
  logo            String?
  phone           String?
  email           String?
  address         String?
  legalName       String?
  brandName       String?
  gstNumber       String?
  panNumber       String?
  fssaiNumber     String?
  timezone        String       @default("Asia/Kolkata")
  currency        String       @default("INR")
  isActive        Boolean      @default(true)
  status          TenantStatus @default(ACTIVE)
  businessType    String?
  country         String?      @default("India")
  state           String?
  city            String?
  onboardingStatus String      @default("NOT_STARTED")
  version         Int          @default(1)
  createdBy       String?
  deletedAt       DateTime?
  archivedAt      DateTime?
  deletedBy       String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  branches             Branch[]
  users                User[]
  roles                Role[]
  categories           Category[]
  menuItems            MenuItem[]
  combos               Combo[]
  inventoryItems       InventoryItem[]
  suppliers            Supplier[]
  subscriptions        Subscription[]
  reservations         Reservation[]
  purchases            Purchase[]
  auditLogs            AuditLog[]
  notifications        Notification[]
  couponUsages         CouponUsage[]
  paymentPromises      PaymentPromise[]
  supportTickets       SupportTicket[]
  websiteConfig        TenantWebsiteConfig?
  customers            Customer[]
  conversationSessions ConversationSession[]
  membershipTiers      MembershipTier[]
  reviews              Review[]
  feedbacks            Feedback[]
  staff                Staff[]
  orders               Order[]
  deliveryPartners     DeliveryPartner[]
  wallets              Wallet[]
  loyaltyPoints        LoyaltyPoints[]
  tenantFeatureFlags   TenantFeatureFlag[]
  leaveRequests        LeaveRequest[]
  payrolls             Payroll[]
  transactions         Transaction[]
  campaigns            Campaign[]
  emailTemplates       EmailTemplate[]
  audienceSegments     AudienceSegment[]
  tenantSettings       TenantSetting[]
  taxSettings          TaxSetting[]
  apiKeys              ApiKey[]
  webhooks             Webhook[]
  workflowTemplates    WorkflowTemplate[]
  workflowRequests     WorkflowRequest[]
  provisionRequests    RestaurantProvisionRequest[]
  offers               Offer[]
  announcements        Announcement[]
  galleryImages        GalleryImage[]

  dailySnapshots       DailyAnalyticsSnapshot[]
  hourlySnapshots      HourlyAnalyticsSnapshot[]
  branchSnapshots      BranchAnalyticsSnapshot[]
  forecastSnapshots    ForecastSnapshot[]
  kpiGoals             KpiGoal[]
  kpiAlerts            KpiAlert[]
   aiConversations      AIConversation[]
   aiReports            AIReport[]
   aiUsage              AIUsage[]
    payments             Payment[]
    customDomains        CustomDomain[]
    businessHours        BusinessHours[]
    deliverySettings     DeliverySettings?
    paymentSettings      PaymentSettings?
    contactMessages      ContactMessage[]
    invoices             Invoice[]
    diningSessions       DiningSession[]
    whatsappAccounts     WhatsAppAccount[]
    whatsappMessages     WhatsAppMessage[]
    whatsappTemplates    WhatsAppTemplate[]
    whatsappTemplateUsages WhatsAppTemplateUsage[]
    whatsappCampaigns    WhatsAppBulkCampaign[]
    whatsappAutomations  WhatsAppAutomation[]
    whatsappAnalytics    WhatsAppAnalytics[]
      mediaAssets          MediaAsset[]
      websiteRevisions     WebsiteRevision[]
      testimonials         Testimonial[]
      faqs                 Faq[]
      blogPosts            BlogPost[]
      events               Event[]

  @@index([ownerProfileId])
  @@map("tenants")
}

model Branch {
  id             String       @id @default(cuid())
  tenantId       String
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name           String
  displayName    String?
  code           String?
  branchType     BranchType   @default(PRIMARY)
  address        String?
  city           String?
  state          String?
  country        String?      @default("India")
  postalCode     String?
  latitude       Float?
  longitude      Float?
  phone          String?
  email          String?
  gstin          String?
  fssai          String?
  timezone       String?
  currency       String?
  managerId      String?
  diningCapacity Int?
  deliveryRadius Float?
  businessHours  Json?
  printerConfig  Json?
  posConfig      Json?
  qrConfig       Json?
  theme          Json?
  isPrimary      Boolean      @default(false)
  isActive       Boolean      @default(true)
  status         BranchStatus @default(ACTIVE)
  version        Int          @default(1)
  deletedAt      DateTime?
  archivedAt     DateTime?
  deletedBy      String?
  createdBy      String?
  updatedBy      String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  channelRestaurantMappings ChannelRestaurantMapping[]
  tables                    RestaurantTable[]
  orders                    Order[]
  staff                     Staff[]
  shifts                    Shift[]
  payments                  Payment[]
  deliveryPartners          DeliveryPartner[]
  deliveries                Delivery[]
  conversationSessions      ConversationSession[]
  leaveRequests             LeaveRequest[]
  payrolls                  Payroll[]
  transactions              Transaction[]
  campaigns                 Campaign[]
  subscriptions             Subscription[]
  offers                    Offer[]
  announcements             Announcement[]
  galleryImages             GalleryImage[]
  diningSessions            DiningSession[]

  branchSnapshots          BranchAnalyticsSnapshot[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("branches")
}

// ─────────────────────────────────────────────
// AUTH & USERS
// ─────────────────────────────────────────────

model User {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email       String    @unique
  phone       String?
  password    String
  firstName   String
  lastName    String
  avatar      String?
  role        UserRole  @default(STAFF)
  isActive    Boolean   @default(true)
  lastLoginAt DateTime?
  deletedAt   DateTime?
  createdBy   String?
  updatedBy   String?
  version     Int       @default(1)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  staff         Staff[]
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]
  notifications Notification[]

  @@index([tenantId])
  @@index([phone])
  @@map("users")
}

enum UserRole {
  OWNER
  MANAGER
  STAFF
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  userAgent String?
  ipAddress String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────
// ROLE & PERMISSIONS
// ─────────────────────────────────────────────

model Role {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  description String?
  isSystem    Boolean   @default(false)
  version     Int       @default(1)
  deletedAt   DateTime?
  createdBy   String?
  updatedBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  permissions RolePermission[]
  staff       Staff[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("roles")
}

model Permission {
  id          String  @id @default(cuid())
  module      String
  action      String
  description String?

  roles RolePermission[]

  @@unique([module, action])
  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model Staff {
  id          String      @id @default(cuid())
  tenantId    String
  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId    String
  branch      Branch      @relation(fields: [branchId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  roleId      String
  role        Role        @relation(fields: [roleId], references: [id], onDelete: Cascade)
  managerId   String?
  name        String
  phone       String?
  pin         String?
  salary      Decimal?    @db.Decimal(10, 2)
  status      StaffStatus @default(ACTIVE)
  isActive    Boolean     @default(true)
  joiningDate DateTime?
  leavingDate DateTime?
  deletedAt   DateTime?
  archivedAt  DateTime?
  deletedBy   String?
  createdBy   String?
  updatedBy   String?
  version     Int         @default(1)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  orders         Order[]
  shifts         StaffShift[]
  attendance     Attendance[]
  leaveRequests  LeaveRequest[]
  payrolls       Payroll[]
  approvedLeaves LeaveRequest[] @relation("LeaveApprover")

  @@index([branchId])
  @@index([tenantId])
  @@map("staff")
}

// ─────────────────────────────────────────────
// MENU
// ─────────────────────────────────────────────

model Category {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  description String?
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  image       String?
  deletedAt   DateTime?
  createdBy   String?
  updatedBy   String?
  version     Int       @default(1)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  items MenuItem[]

  @@index([tenantId])
  @@map("categories")
}

model MenuItem {
  id                   String    @id @default(cuid())
  tenantId             String
  tenant               Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  categoryId           String
  category             Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name                 String
  description          String?
  price                Decimal   @db.Decimal(10, 2)
  costPrice            Decimal?  @db.Decimal(10, 2)
  sku                  String?
  barcode              String?
  image                String?
  isVeg                Boolean   @default(false)
  isAvailable          Boolean   @default(true)
  isPopular            Boolean   @default(false)
  isBestSeller         Boolean   @default(false)
  isChefRecommendation Boolean   @default(false)
  isTodaySpecial       Boolean   @default(false)
  isNew                Boolean   @default(false)
  isSeasonal           Boolean   @default(false)
  prepTimeMin          Int?
  sortOrder            Int       @default(0)
  taxRate              Decimal   @default(0) @db.Decimal(5, 2)
  tags                 String[]
  version              Int       @default(1)
  deletedAt            DateTime?
  createdBy            String?
  updatedBy            String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  channelItemMappings ChannelItemMapping[]
  variants            MenuItemVariant[]
  addOns              MenuItemAddOn[]
  comboItems          ComboItem[]
  images              MenuItemImage[]
  orderItems          OrderItem[]
  inventoryItems      InventoryItem[]
  recipeItems         RecipeItem[]
  sharedItems         SharedItem[]
  guestCartItems      GuestCartItem[]

  @@index([tenantId])
  @@index([categoryId])
  @@index([barcode])
  @@map("menu_items")
}

model MenuItemImage {
  id         String   @id @default(cuid())
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  url        String
  sortOrder  Int      @default(0)
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([menuItemId])
  @@map("menu_item_images")
}

model MenuItemVariant {
  id         String   @id @default(cuid())
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  name       String
  price      Decimal  @db.Decimal(10, 2)
  isActive   Boolean  @default(true)

  @@index([menuItemId])
  @@map("menu_item_variants")
}

model MenuItemAddOn {
  id         String   @id @default(cuid())
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  name       String
  price      Decimal  @db.Decimal(10, 2)
  isActive   Boolean  @default(true)

  @@index([menuItemId])
  @@map("menu_item_add_ons")
}

model Combo {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  description String?
  price       Decimal   @db.Decimal(10, 2)
  isActive    Boolean   @default(true)
  image       String?
  sortOrder   Int       @default(0)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  items       ComboItem[]

  @@index([tenantId])
  @@map("combos")
}

model ComboItem {
  id         String   @id @default(cuid())
  comboId    String
  combo      Combo    @relation(fields: [comboId], references: [id], onDelete: Cascade)
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  quantity   Int      @default(1)

  @@index([comboId])
  @@index([menuItemId])
  @@map("combo_items")
}

// ─────────────────────────────────────────────
// TABLES
// ─────────────────────────────────────────────

model RestaurantTable {
  id              String           @id @default(cuid())
  branchId        String
  branch          Branch           @relation(fields: [branchId], references: [id], onDelete: Cascade)
  number          Int
  name            String?
  capacity        Int              @default(4)
  status          TableStatus      @default(FREE)
  qrCode          String?
  activeSessionId String?   @unique
  activeSession   DiningSession?   @relation("DiningSessionActiveTable", fields: [activeSessionId], references: [id], onDelete: SetNull)
  isActive        Boolean          @default(true)
  version         Int              @default(1)
  deletedAt       DateTime?
  createdBy       String?
  updatedBy       String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  orders       Order[]
  reservations Reservation[]
  diningSessions DiningSession[] @relation("DiningSessionTable")

  @@unique([branchId, number])
  @@map("restaurant_tables")
}

enum TableStatus {
  FREE
  OCCUPIED
  RESERVED
  CLEANING
  ORDER_READY
  BILLING
}

// ─────────────────────────────────────────────
// ORDERS
// ─────────────────────────────────────────────

model Order {
  id              String           @id @default(cuid())
  branchId        String
  branch          Branch           @relation(fields: [branchId], references: [id], onDelete: Cascade)
  tableId         String?
  table           RestaurantTable? @relation(fields: [tableId], references: [id], onDelete: SetNull)
  staffId         String?
  staff           Staff?           @relation(fields: [staffId], references: [id], onDelete: SetNull)
  tenantId        String
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  diningSessionId String?
  diningSession   DiningSession?   @relation(fields: [diningSessionId], references: [id], onDelete: SetNull)
  guestSessionId  String?
  guestSession    GuestSession?    @relation(fields: [guestSessionId], references: [id], onDelete: SetNull)
  orderNumber     Int
  type            OrderType
  status          OrderStatus      @default(PENDING)
  orderSource     OrderSource      @default(POS)

  // ── Channel/External Order Fields ──
  channel              OrderChannel @default(DINE_IN)
  channelOrderId       String?
  idempotencyKey       String?      @unique
  channelStatus        String?
  channelData          Json?
  channelRawPayloadRef String?
  needsManualReview    Boolean      @default(false)

  customerName   String?
  customerPhone  String?
  guestCount     Int?
  subtotal       Decimal   @db.Decimal(10, 2)
  taxAmount      Decimal   @db.Decimal(10, 2)
  discountAmount Decimal   @default(0) @db.Decimal(10, 2)
  totalAmount    Decimal   @db.Decimal(10, 2)
  notes          String?
  kotPrinted     Boolean   @default(false)
  synced         Boolean   @default(false)
  localId        String?
  version        Int       @default(1)
  deletedAt      DateTime?
  deletedBy      String?
  createdBy      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  items                OrderItem[]
  payments             Payment[]
  statusHistory        OrderStatusHistory[]
  reviews              Review[]
  conversationSessions ConversationSession[]
  deliveries           Delivery[]
  loyaltyTransactions  LoyaltyTransaction[]
  walletTransactions   WalletTransaction[]
  transactions         Transaction[]
  whatsappMessages     WhatsAppMessage[]

  @@unique([channelOrderId, channel])
  @@index([branchId, status])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, branchId])
  @@index([createdAt])
  @@index([channel])
  @@map("orders")
}

enum OrderChannel {
  DINE_IN
  QR
  APP
  SWIGGY
  ZOMATO
  WHATSAPP
  INSTAGRAM
  FACEBOOK
  ONDC

  @@map("order_channels")
}

enum OrderType {
  DINE_IN
  TAKEAWAY
  DELIVERY
  QR_ORDER
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  SERVED
  COMPLETED
  CANCELLED
  REJECTED
  OUT_FOR_DELIVERY
  AWAITING_PICKUP
}

model OrderItem {
  id         String          @id @default(cuid())
  orderId    String
  order      Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId String
  menuItem   MenuItem        @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  variantId  String?
  name       String
  quantity   Int
  unitPrice  Decimal         @db.Decimal(10, 2)
  totalPrice Decimal         @db.Decimal(10, 2)
  notes      String?
  status     OrderItemStatus @default(PENDING)
  version    Int             @default(1)
  deletedAt  DateTime?
  createdBy  String?
  updatedBy  String?

  addOns OrderItemAddOn[]

  @@index([orderId])
  @@map("order_items")
}

enum OrderItemStatus {
  PENDING
  PREPARING
  READY
  SERVED
  CANCELLED
}

model OrderItemAddOn {
  id          String    @id @default(cuid())
  orderItemId String
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  name        String
  price       Decimal   @db.Decimal(10, 2)

  @@index([orderItemId])
  @@map("order_item_add_ons")
}

model OrderStatusHistory {
  id        String      @id @default(cuid())
  orderId   String
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    OrderStatus
  notes     String?
  createdBy String?
  createdAt DateTime    @default(now())

  @@index([orderId])
  @@map("order_status_history")
}

// ─────────────────────────────────────────────
// PAYMENTS
// ─────────────────────────────────────────────

model Payment {
  id             String        @id @default(cuid())
  tenantId       String
  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orderId        String
  order          Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  branchId       String
  branch         Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  guestSessionId String?
  guestSession   GuestSession? @relation(fields: [guestSessionId], references: [id], onDelete: SetNull)
  method         PaymentMethod
  amount         Decimal       @db.Decimal(10, 2)
  reference      String?
  status         PaymentStatus @default(PENDING)
  receivedAt     DateTime      @default(now())
  version        Int           @default(1)
  deletedAt      DateTime?
  createdBy      String?
  updatedBy      String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  invoice              Invoice?
  paymentTransactions  PaymentTransaction[]

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([orderId])
  @@index([branchId])
  @@index([guestSessionId])
  @@map("payments")
}

enum PaymentMethod {
  CASH
  UPI
  CREDIT_CARD
  DEBIT_CARD
  NET_BANKING
  WALLET
  ONLINE
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

// ─────────────────────────────────────────────
// DINING SESSION ENUMS
// ─────────────────────────────────────────────

enum DiningSessionStatus {
  ACTIVE
  ORDERING
  DINING
  BILLING
  SETTLED
  CLOSED
  ABANDONED
}

enum GuestSessionStatus {
  JOINED
  ORDERING
  ORDERED
  PAYING
  PAID
  LEFT
}

enum SplitType {
  FULL_BILL
  BY_GUEST
  BY_ITEM
  EQUAL_SPLIT
  CUSTOM
}

enum SplitAllocationStatus {
  PENDING
  ACCEPTED
  PAID
  CANCELLED
}

enum SharedItemSplitMode {
  EQUAL
  PERCENTAGE
  CUSTOM_AMOUNT
}

model Invoice {
  id        String    @id @default(cuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  paymentId String    @unique
  payment   Payment   @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  number    String
  gstAmount Decimal   @db.Decimal(10, 2)
  cgst      Decimal   @db.Decimal(10, 2)
  sgst      Decimal   @db.Decimal(10, 2)
  igst      Decimal   @db.Decimal(10, 2)
  pdfUrl    String?
  version   Int       @default(1)
  deletedAt DateTime?
  createdBy String?
  updatedBy String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@map("invoices")
}

// ─────────────────────────────────────────────
// INVENTORY
// ─────────────────────────────────────────────

model InventoryItem {
  id              String    @id @default(cuid())
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name            String
  unit            String
  currentStock    Decimal   @default(0) @db.Decimal(10, 2)
  minimumStock    Decimal   @default(0) @db.Decimal(10, 2)
  costPrice       Decimal   @db.Decimal(10, 2)
  reorderQuantity Decimal?  @db.Decimal(10, 2)
  barcode         String?
  version         Int       @default(1)
  deletedAt       DateTime?
  createdBy       String?
  updatedBy       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  stockMovements StockMovement[]
  purchaseItems  PurchaseItem[]
  menuItems      MenuItem[]
  recipeItems    RecipeItem[]

  @@index([tenantId])
