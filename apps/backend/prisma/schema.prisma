  guestSessions GuestSession[]
  orders        Order[]
  sharedItems   SharedItem[]
  splitAllocations SplitAllocation[]
  sessionTimelines SessionTimeline[]

  @@index([tenantId])
  @@index([tenantId, branchId])
  @@index([tenantId, branchId, status])
  @@index([tableId])
  @@index([sessionCode])
  @@index([tenantId, createdAt])
  @@map("dining_sessions")
}

model GuestSession {
  id               String            @id @default(cuid())
  diningSessionId  String
  diningSession    DiningSession     @relation(fields: [diningSessionId], references: [id], onDelete: Cascade)
  guestToken       String            @unique
  guestName        String?
  guestNumber      Int?
  avatarColor      String?
  deviceFingerprint String?
  status           GuestSessionStatus @default(JOINED)
  joinedAt         DateTime          @default(now())
  lastActivityAt   DateTime          @default(now())
  leftAt           DateTime?
  deviceInfo       Json?
  metadata         Json?
  version          Int               @default(1)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  orders         Order[]
  cartItems      GuestCartItem[]
  payments       Payment[]
  splitAllocations SplitAllocation[]
  sharedItemAllocations SharedItemAllocation[]
  paymentTransactions  PaymentTransaction[]

  @@index([diningSessionId])
  @@index([guestToken])
  @@index([diningSessionId, status])
  @@map("guest_sessions")
}

model GuestCartItem {
