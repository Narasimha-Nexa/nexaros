  onboardedAt          DateTime?
  lastSyncAt           DateTime?
  version              Int          @default(1)
  deletedAt            DateTime?
  createdBy            String?
  updatedBy            String?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

