# ─── DATABASE ───
DATABASE_URL=postgresql://nexaros:nexaros_dev@localhost:5433/nexaros

# ─── REDIS ───
REDIS_URL=redis://localhost:6379

# ─── JWT ───
JWT_SECRET=change-this-to-a-random-64-character-string
JWT_REFRESH_SECRET=change-this-to-another-random-64-character-string
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ─── APP ───
PORT=4000
NODE_ENV=development
APP_URL=http://localhost:4000
APP_NAME=NexaROS

# ─── CORS ───
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:8080

